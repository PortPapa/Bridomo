<Window x:Class="LocalTrafficInspector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LocalTrafficInspector.Converters"
        Title="Local Traffic Inspector"
        Height="780" Width="1300"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:StatusCodeBrushConverter x:Key="StatusBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>    <!-- 타이틀 바 -->
            <RowDefinition Height="Auto"/>  <!-- 커맨드 바 -->
            <RowDefinition Height="Auto"/>  <!-- 필터 바 -->
            <RowDefinition Height="*"/>     <!-- 콘텐츠 -->
            <RowDefinition Height="Auto"/>  <!-- 상태 바 -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 커스텀 타이틀 바 -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 타이틀 텍스트 (드래그 영역) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="Local Traffic Inspector" FontSize="12"
                               Foreground="{DynamicResource DimTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 창 컨트롤 버튼 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- 최소화 -->
                    <Button x:Name="MinimizeBtn" Click="MinimizeBtn_Click"
                            Width="46" Height="32" BorderThickness="0"
                            Background="Transparent" Cursor="Hand"
                            FontFamily="Consolas" FontSize="14"
                            Foreground="{DynamicResource DimTextBrush}"
                            Content="&#x2500;">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 최대화/복원 -->
                    <Button x:Name="MaximizeBtn" Click="MaximizeBtn_Click"
                            Width="46" Height="32" BorderThickness="0"
                            Background="Transparent" Cursor="Hand"
                            FontFamily="Consolas" FontSize="12"
                            Foreground="{DynamicResource DimTextBrush}"
                            Content="&#x25A1;">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 닫기 -->
                    <Button x:Name="CloseBtn" Click="CloseBtn_Click"
                            Width="46" Height="32" BorderThickness="0"
                            Background="Transparent" Cursor="Hand"
                            FontFamily="Consolas" FontSize="14"
                            Foreground="{DynamicResource DimTextBrush}"
                            Content="&#x2715;">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#c42b1c"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 커맨드 바 -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,1">
            <DockPanel>
                <!-- 좌측: 메인 액션 -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 상태 표시등 + 앱 이름 -->
                    <Ellipse Width="7" Height="7" Margin="8,0,5,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource DimTextBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="LTI" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>

                    <!-- 구분선 -->
                    <Border Width="1" Background="{DynamicResource BorderBrush}"
                            Margin="4,5" VerticalAlignment="Stretch"/>

                    <!-- Run/Stop -->
                    <Button Style="{StaticResource CommandBarButton}"
                            Command="{Binding StartStopCommand}">
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding StartStopButtonText}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <!-- Chrome -->
                    <Button Style="{StaticResource CommandBarButton}"
                            Command="{Binding LaunchChromeCommand}"
                            Content="Chrome"/>

                    <Border Width="1" Background="{DynamicResource BorderBrush}"
                            Margin="4,5" VerticalAlignment="Stretch"/>

                    <!-- Clear -->
                    <Button Style="{StaticResource CommandBarButton}"
                            Command="{Binding ClearCommand}"
                            Content="Clear"/>

                    <!-- Export -->
                    <Button Style="{StaticResource CommandBarButton}"
                            Command="{Binding ExportJsonCommand}"
                            Content="Export"/>

                    <!-- Macro -->
                    <Button Style="{StaticResource CommandBarButton}"
                            Command="{Binding ExportMacroCommand}">
                        <TextBlock Text="Macro" Foreground="{DynamicResource AccentOrangeBrush}"/>
                    </Button>

                    <Border Width="1" Background="{DynamicResource BorderBrush}"
                            Margin="4,5" VerticalAlignment="Stretch"/>

                    <!-- Layout toggle -->
                    <Button Style="{StaticResource CommandBarButton}"
                            Command="{Binding ToggleLayoutCommand}"
                            Content="Layout" ToolTip="상하/좌우 전환"/>
                </StackPanel>

                <!-- 우측: 설정 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- 광고 숨김 토글 -->
                    <CheckBox IsChecked="{Binding HideJunkApis}" VerticalAlignment="Center"
                              Margin="0,0,6,0">
                        <TextBlock Text="Hide Junk" FontSize="10"
                                   Foreground="{DynamicResource DimTextBrush}"/>
                    </CheckBox>
                    <!-- 정크만 보기 -->
                    <CheckBox IsChecked="{Binding ShowOnlyJunk}" VerticalAlignment="Center"
                              Margin="0,0,8,0">
                        <TextBlock Text="Junk Only" FontSize="10"
                                   Foreground="{DynamicResource AccentRedBrush}"/>
                    </CheckBox>

                    <Border Width="1" Background="{DynamicResource BorderBrush}"
                            Margin="4,5" VerticalAlignment="Stretch"/>

                    <!-- Settings -->
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource CommandBarButton}"
                            Command="{Binding ToggleSettingsCommand}"
                            Content="Settings"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 설정 Popup -->
        <!-- ═══════════════════════════════════════════ -->
        <Popup IsOpen="{Binding IsSettingsPanelOpen, Mode=TwoWay}"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=SettingsButton}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Width="260" Padding="14,12"
                    CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,12"/>

                    <!-- Address -->
                    <TextBlock Text="address" FontSize="10"
                               Foreground="{DynamicResource DimTextBrush}" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding ListenAddress, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEditSettings}"/>

                    <!-- Port -->
                    <TextBlock Text="port" FontSize="10"
                               Foreground="{DynamicResource DimTextBrush}" Margin="0,10,0,3"/>
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEditSettings}" Width="80"
                             HorizontalAlignment="Left"/>

                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,14"/>

                    <CheckBox Content="{DynamicResource Str_Https}" IsChecked="{Binding EnableSsl}"
                              IsEnabled="{Binding CanEditSettings}" Margin="0,4"/>
                    <CheckBox Content="{DynamicResource Str_JsonPretty}" IsChecked="{Binding JsonPrettyPrint}"
                              Margin="0,4"/>

                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,14"/>

                    <!-- Language -->
                    <TextBlock Text="language" FontSize="10"
                               Foreground="{DynamicResource DimTextBrush}" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding LanguageDisplayNames}"
                              SelectedItem="{Binding SelectedLanguageDisplay}"
                              FontSize="11"/>

                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,14"/>

                    <!-- Certificate -->
                    <Button Content="{DynamicResource Str_CertInfo}"
                            Command="{Binding ShowCertInfoCommand}"
                            Style="{StaticResource ActionButton}"
                            HorizontalAlignment="Left" Margin="0,4"/>
                    <TextBlock Text="{Binding CertificateStatus}"
                               FontSize="10" Foreground="{DynamicResource DimTextBrush}" Margin="0,4"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 필터 바 -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource BgBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text=">" FontSize="13"
                           Foreground="{DynamicResource AccentGreenBrush}"
                           VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="filter:" FontSize="11"
                           Foreground="{DynamicResource DimTextBrush}"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Grid.Column="2"
                         Text="{Binding FilterHost, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{DynamicResource Str_SearchTooltip}"/>

                <TextBlock Grid.Column="3" Text="method:" FontSize="11"
                           Foreground="{DynamicResource DimTextBrush}"
                           VerticalAlignment="Center" Margin="12,0,4,0"/>
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding MethodOptions}"
                          SelectedItem="{Binding FilterMethod}"/>

                <TextBlock Grid.Column="5" Text="status:" FontSize="11"
                           Foreground="{DynamicResource DimTextBrush}"
                           VerticalAlignment="Center" Margin="12,0,4,0"/>
                <TextBox Grid.Column="6"
                         Text="{Binding FilterStatusCode, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 메인 콘텐츠 -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Row="3" x:Name="ContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ContentRow0" Height="*" MinHeight="120"/>
                <RowDefinition x:Name="SplitterRow" Height="4"/>
                <RowDefinition x:Name="ContentRow2" Height="*" MinHeight="120"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ContentCol0" Width="*"/>
                <ColumnDefinition x:Name="SplitterCol" Width="0"/>
                <ColumnDefinition x:Name="ContentCol2" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- 요청 리스트 -->
            <DataGrid x:Name="RequestGrid" Grid.Row="0" Grid.Column="0"
                      Style="{StaticResource DarkDataGrid}"
                      ItemsSource="{Binding SessionsView}"
                      SelectedItem="{Binding SelectedSession}">

                <DataGrid.ContextMenu>
                    <ContextMenu Background="{DynamicResource PanelBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 FontFamily="Consolas" FontSize="11">
                        <MenuItem Header="이 URL을 정크에 추가"
                                  Command="{Binding AddUrlToJunkCommand}"
                                  Foreground="{DynamicResource TextBrush}"/>
                        <MenuItem Header="이 호스트 전체를 정크에 추가"
                                  Command="{Binding AddToJunkCommand}"
                                  CommandParameter="{Binding SelectedSession.Host}"
                                  Foreground="{DynamicResource DimTextBrush}"/>
                        <MenuItem Header="이 호스트를 정크에서 제거"
                                  Command="{Binding RemoveFromJunkCommand}"
                                  CommandParameter="{Binding SelectedSession.Host}"
                                  Foreground="{DynamicResource TextBrush}"/>
                        <Separator Background="{DynamicResource BorderBrush}"/>
                        <MenuItem Header="이 호스트만 보기"
                                  Foreground="{DynamicResource TextBrush}"
                                  Click="FilterByHost_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="45"/>
                    <DataGridTextColumn Binding="{Binding TimestampDisplay}" Width="85">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Str_ColTime}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding Method}" Width="55">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Str_ColMethod}"/>
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentYellowBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding Host}" Width="170">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Str_ColHost}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding Url}" Width="*">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Str_ColUrl}"/>
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource DimTextBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding StatusCodeDisplay}" Width="45">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Str_ColStatus}"/>
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground"
                                        Value="{Binding StatusCode, Converter={StaticResource StatusBrush}}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding ContentType}" Width="120">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Str_ColType}"/>
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource DimTextBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding DurationMs, StringFormat={}{0}ms}" Width="60">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Str_ColDuration}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 분할선 -->
            <GridSplitter x:Name="ContentSplitter" Grid.Row="1" Grid.Column="0"
                          Grid.ColumnSpan="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Cursor="SizeNS"/>

            <!-- 상세 탭 -->
            <TabControl x:Name="DetailTabs" Grid.Row="2" Grid.Column="0"
                        Style="{StaticResource DarkTabControl}">
                <TabItem Style="{StaticResource DarkTabItem}">
                    <TabItem.Header>
                        <TextBlock Text="{DynamicResource Str_TabOverview}"/>
                    </TabItem.Header>
                    <TextBox Text="{Binding OverviewText, Mode=OneWay}"
                             IsReadOnly="True" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10" BorderThickness="0"
                             Background="{DynamicResource BgBrush}"/>
                </TabItem>

                <TabItem Style="{StaticResource DarkTabItem}">
                    <TabItem.Header>
                        <TextBlock Text="{DynamicResource Str_TabReqHeaders}"/>
                    </TabItem.Header>
                    <TextBox Text="{Binding RequestHeadersText, Mode=OneWay}"
                             IsReadOnly="True" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Padding="10"
                             BorderThickness="0"
                             Background="{DynamicResource BgBrush}"/>
                </TabItem>

                <TabItem Style="{StaticResource DarkTabItem}">
                    <TabItem.Header>
                        <TextBlock Text="{DynamicResource Str_TabReqBody}"/>
                    </TabItem.Header>
                    <TextBox Text="{Binding RequestBodyText, Mode=OneWay}"
                             IsReadOnly="True" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Padding="10"
                             BorderThickness="0"
                             Background="{DynamicResource BgBrush}"/>
                </TabItem>

                <TabItem Style="{StaticResource DarkTabItem}">
                    <TabItem.Header>
                        <TextBlock Text="{DynamicResource Str_TabRespHeaders}"/>
                    </TabItem.Header>
                    <TextBox Text="{Binding ResponseHeadersText, Mode=OneWay}"
                             IsReadOnly="True" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Padding="10"
                             BorderThickness="0"
                             Background="{DynamicResource BgBrush}"/>
                </TabItem>

                <TabItem Style="{StaticResource DarkTabItem}">
                    <TabItem.Header>
                        <TextBlock Text="{DynamicResource Str_TabRespBody}"/>
                    </TabItem.Header>
                    <TextBox Text="{Binding ResponseBodyText, Mode=OneWay}"
                             IsReadOnly="True" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Padding="10"
                             BorderThickness="0"
                             Background="{DynamicResource BgBrush}"/>
                </TabItem>

                <TabItem Style="{StaticResource DarkTabItem}">
                    <TabItem.Header>
                        <TextBlock Text="{DynamicResource Str_TabDomEvents}"
                                   Foreground="{DynamicResource AccentOrangeBrush}"/>
                    </TabItem.Header>
                    <DataGrid Style="{StaticResource DarkDataGrid}"
                              ItemsSource="{Binding DomEvents}"
                              x:Name="DomGrid">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="이 이벤트 삭제"
                                          Click="DeleteDomEvent_Click"
                                          Foreground="{DynamicResource AccentRedBrush}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="35"/>
                            <DataGridTextColumn Binding="{Binding TimestampDisplay}" Width="80">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Str_DomColTime}"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding EventType}" Width="55">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Str_DomColType}"/>
                                </DataGridTextColumn.Header>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Summary}" Width="220">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Str_DomColSummary}"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Url}" Width="*">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Str_DomColUrl}"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding MatchStatus}" Width="65">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Str_DomColMatch}"/>
                                </DataGridTextColumn.Header>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 상태 바 -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="10,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="11" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" Text="{Binding SessionCountText}" FontSize="11" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="2" Text="{Binding DomEventCountText}" FontSize="11"
                           Foreground="{DynamicResource AccentOrangeBrush}" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="3" Text="{Binding WsStatus}" FontSize="11"
                           Foreground="{DynamicResource AccentBlueBrush}"/>
                <TextBlock Grid.Column="5" Text="{Binding CertificateStatus}" FontSize="10"
                           Foreground="{DynamicResource DimTextBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
