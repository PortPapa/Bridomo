{
  "manifest_version": 3,
  "name": "DOM Recorder",
  "version": "1.0.0",
  "description": "Records DOM interactions and sends to LocalTrafficInspector via WebSocket",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DOM Recorder"
  }
}
