<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Toolbar -->
    <sys:String x:Key="Str_Start">Run</sys:String>
    <sys:String x:Key="Str_Stop">Stop</sys:String>
    <sys:String x:Key="Str_Clear">Clear</sys:String>
    <sys:String x:Key="Str_ExportJson">Export JSON</sys:String>
    <sys:String x:Key="Str_ExportTxt">Export TXT</sys:String>
    <sys:String x:Key="Str_Address">Address:</sys:String>
    <sys:String x:Key="Str_Port">Port:</sys:String>
    <sys:String x:Key="Str_Https">HTTPS</sys:String>
    <sys:String x:Key="Str_JsonPretty">JSON Pretty</sys:String>
    <sys:String x:Key="Str_CertInfo">Cert Info</sys:String>
    <sys:String x:Key="Str_Language">Language</sys:String>

    <!-- Filter -->
    <sys:String x:Key="Str_Search">Search:</sys:String>
    <sys:String x:Key="Str_Method">Method:</sys:String>
    <sys:String x:Key="Str_Status">Status:</sys:String>
    <sys:String x:Key="Str_SearchTooltip">Search by Host or URL</sys:String>
    <sys:String x:Key="Str_StatusTooltip">200, 404, 2xx, 4xx, 5xx</sys:String>

    <!-- DataGrid Headers -->
    <sys:String x:Key="Str_ColTime">Time</sys:String>
    <sys:String x:Key="Str_ColMethod">Method</sys:String>
    <sys:String x:Key="Str_ColHost">Host</sys:String>
    <sys:String x:Key="Str_ColUrl">URL</sys:String>
    <sys:String x:Key="Str_ColStatus">Status</sys:String>
    <sys:String x:Key="Str_ColType">Type</sys:String>
    <sys:String x:Key="Str_ColDuration">Duration</sys:String>
    <sys:String x:Key="Str_ColProto">Proto</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="Str_TabOverview">Overview</sys:String>
    <sys:String x:Key="Str_TabReqHeaders">Request Headers</sys:String>
    <sys:String x:Key="Str_TabReqBody">Request Body</sys:String>
    <sys:String x:Key="Str_TabRespHeaders">Response Headers</sys:String>
    <sys:String x:Key="Str_TabRespBody">Response Body</sys:String>

    <!-- Status messages -->
    <sys:String x:Key="Str_ProxyRunning">Proxy running on</sys:String>
    <sys:String x:Key="Str_ProxyStopped">Proxy stopped</sys:String>
    <sys:String x:Key="Str_Total">Total:</sys:String>
    <sys:String x:Key="Str_NoSessionsToExport">No sessions to export.</sys:String>
    <sys:String x:Key="Str_ExportComplete">sessions exported.</sys:String>
    <sys:String x:Key="Str_ExportFailed">Export failed:</sys:String>
    <sys:String x:Key="Str_ProxyStartFailed">Proxy start failed:</sys:String>
    <sys:String x:Key="Str_CertInstalled">Cert: Installed</sys:String>
    <sys:String x:Key="Str_CertNotInstalled">Cert: Not Installed</sys:String>

    <!-- Certificate dialog -->
    <sys:String x:Key="Str_CertTitle">HTTPS Certificate Status</sys:String>
    <sys:String x:Key="Str_CertInstalledMsg">HTTPS certificate is installed. HTTPS traffic capture is available.</sys:String>
    <sys:String x:Key="Str_CertNotInstalledMsg">HTTPS certificate is not installed.

To capture HTTPS traffic:
1. Start the proxy with HTTPS mode - a certificate will be generated automatically.
2. Click 'Yes' when the system asks to trust the certificate.
3. Restart your browser.

The certificate is for local development/debugging only.</sys:String>
    <sys:String x:Key="Str_CertInstallAsk">Would you like to install the certificate now?</sys:String>
    <sys:String x:Key="Str_CertUninstallAsk">Would you like to uninstall the certificate?</sys:String>

    <!-- Chrome -->
    <sys:String x:Key="Str_LaunchChrome">Launch Chrome</sys:String>
    <sys:String x:Key="Str_ChromeNotFound">Chrome not found. Please check the installation path.</sys:String>
    <sys:String x:Key="Str_ChromeLaunchFailed">Chrome launch failed:</sys:String>

    <!-- DOM / Macro -->
    <sys:String x:Key="Str_HideJunk">Hide Ads/Tracking</sys:String>
    <sys:String x:Key="Str_TabDomEvents">DOM Events</sys:String>
    <sys:String x:Key="Str_ExportMacro">Macro Export</sys:String>
    <sys:String x:Key="Str_NoDomEvents">No DOM events recorded.</sys:String>
    <sys:String x:Key="Str_DomColTime">Time</sys:String>
    <sys:String x:Key="Str_DomColType">Type</sys:String>
    <sys:String x:Key="Str_DomColSummary">Summary</sys:String>
    <sys:String x:Key="Str_DomColUrl">URL</sys:String>
    <sys:String x:Key="Str_DomColMatch">API Match</sys:String>

</ResourceDictionary>
